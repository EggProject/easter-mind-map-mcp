# Default settings for all files.
* text=auto eol=lf

# Git LFS - big files
*.zip filter=lfs diff=lfs merge=lfs -text
*.gz filter=lfs diff=lfs merge=lfs -text
*.tar filter=lfs diff=lfs merge=lfs -text
*.iso filter=lfs diff=lfs merge=lfs -text

# Image files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.svg text
*.ico binary

# Font files
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary

# Special Git files
.gitattributes text export-ignore eol=lf
.gitignore text export-ignore eol=lf
.gitmodules text export-ignore eol=lf
.gitkeep export-ignore
